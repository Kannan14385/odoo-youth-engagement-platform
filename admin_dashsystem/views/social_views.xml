        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('base.view_users_tree')}), (0, 0, {'view_mode': 'form', 'view_id': ref('base.view_users_form')})]"/>
