<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_inherit_social_funds" model="ir.ui.view">
        <field name="name">account.move.form.inherit.social</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <field name="fund_project_id"/>
                <field name="audit_status" widget="badge"
                       decoration-success="audit_status == 'cleared'"
                       decoration-warning="audit_status == 'pending'"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_tree_inherit_social_funds" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.social</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">

            <field name="name" position="after">
                <field name="audit_status" widget="badge" optional="show"
                       decoration-success="audit_status == 'cleared'"
                       decoration-warning="audit_status == 'pending'"/>
                <field name="fund_project_id" optional="hide"/>
            </field>

        </field>
    </record>

</odoo>