<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_social_award" model="ir.actions.act_window">
        <field name="name">Awards</field>
        <field name="res_model">social.award</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_social_award_list" model="ir.ui.view">
        <field name="name">social.award.list</field>
        <field name="model">social.award</field>
        <field name="arch" type="xml">
            <list>
                <field name="type"/>
                <field name="won_by"/>
                <field name="year_date"/>
            </list>
        </field>
    </record>

    <record id="view_social_award_form" model="ir.ui.view">
        <field name="name">social.award.form</field>
        <field name="model">social.award</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="won_by"/>
                            <field name="year_date"/>
                        </group>
                        <group>
                            <field name="eligibility"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>