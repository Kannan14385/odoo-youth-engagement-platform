<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_social_skill_training" model="ir.actions.act_window">
        <field name="name">Skill Development</field>
        <field name="res_model">social.skill.training</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a new Skill Development Program</p>
        </field>
    </record>

    <record id="view_social_skill_training_list" model="ir.ui.view">
        <field name="name">social.skill.training.list</field>
        <field name="model">social.skill.training</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="organizer"/>
                <field name="subject_area"/>
                <field name="start_date"/>
                <field name="duration"/>
            </list>
        </field>
    </record>

    <record id="view_social_skill_training_form" model="ir.ui.view">
        <field name="name">social.skill.training.form</field>
        <field name="model">social.skill.training</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Name of Training"/>
                        <h1><field name="name" placeholder="e.g. Digital Marketing Workshop"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="organizer" string="By : Organization"/>
                            <field name="subject_area"/>
                        </group>
                        <group>
                            <label for="start_date" string="Dates"/>
                            <div class="o_row">
                                <field name="start_date" widget="daterange" options="{'related_end_date': 'end_date'}"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                <field name="end_date" widget="daterange" options="{'related_start_date': 'start_date'}"/>
                            </div>
                            <field name="duration"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Training Details">
                            <field name="description" placeholder="Additional details about the training..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>