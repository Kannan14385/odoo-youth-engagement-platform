<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_youth_testimonial_list" model="ir.ui.view">
        <field name="name">youth.testimonial.list</field>
        <field name="model">youth.testimonial</field>
        <field name="arch" type="xml">
            <list>
                <field name="contact_person"/>
                <field name="category"/>
                <field name="date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'published'"/>
            </list>
        </field>
    </record>

    <record id="view_youth_testimonial_form" model="ir.ui.view">
        <field name="name">youth.testimonial.form</field>
        <field name="model">youth.testimonial</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" type="object" string="Publish" class="oe_highlight btn-success" invisible="state == 'published'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="contact_person"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="media_filename" invisible="1"/>
                            <field name="media_file" filename="media_filename" widget="binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Testimony Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_youth_testimonial" model="ir.actions.act_window">
    <field name="name">Testimonies</field>
    <field name="res_model">youth.testimonial</field>
    <field name="view_mode">list,form</field>
    </record>
</odoo>