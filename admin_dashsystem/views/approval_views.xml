<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_social_blog_approval" model="ir.actions.act_window">
        <field name="name">Social Blogs</field>
        <field name="res_model">blog.post</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a new blog post!</p>
        </field>
    </record>

    <record id="view_blog_post_backend_kanban" model="ir.ui.view">
        <field name="name">blog.post.backend.kanban</field>
        <field name="model">blog.post</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="approval_status" sample="1">
                <field name="name"/>
                <field name="approval_status"/>
                <field name="author_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="float-end mt-2">
                                    <field name="approval_status" widget="badge"
                                           decoration-info="approval_status == 'pending'"
                                           decoration-success="approval_status == 'approved'"
                                           decoration-danger="approval_status == 'rejected'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_blog_post_approval_form" model="ir.ui.view">
        <field name="name">blog.post.approval.form</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_submit_blog" string="Request Publication" type="object" class="oe_highlight"
                            invisible="approval_status != 'draft'"/>

                    <button name="action_approve_blog" string="Publish Now" type="object" class="btn-success"
                            invisible="approval_status != 'draft'" groups="admin_dashsystem.group_social_admin"/>

                    <button name="action_approve_blog" string="Approve Request" type="object" class="btn-success"
                            invisible="approval_status != 'pending'" groups="admin_dashsystem.group_social_admin"/>

                    <button name="action_reject_blog" string="Reject" type="object" class="btn-danger"
                            invisible="approval_status != 'pending'" groups="admin_dashsystem.group_social_admin"/>

                    <field name="approval_status" widget="statusbar" statusbar_visible="draft,pending,approved"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="view_project_approval_form" model="ir.ui.view">
        <field name="name">project.project.approval.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_submit_project" string="Submit for Approval" type="object" class="oe_highlight"
                        invisible="approval_status != 'draft'"/>

                <button name="action_approve_project" string="Approve Immediately" type="object" class="btn-success"
                        invisible="approval_status != 'draft'" groups="admin_dashsystem.group_social_admin"/>

                <button name="action_approve_project" string="Approve Project" type="object" class="btn-success"
                        invisible="approval_status != 'pending'" groups="admin_dashsystem.group_social_admin"/>

                <button name="action_reject_project" string="Reject" type="object" class="btn-danger"
                        invisible="approval_status != 'pending'" groups="admin_dashsystem.group_social_admin"/>

                <button name="action_reset_project" string="Reset to Draft" type="object"
                        invisible="approval_status not in ('rejected', 'pending')"/>

                <field name="approval_status" widget="statusbar" statusbar_visible="draft,pending,approved"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="approval_status" widget="badge" decoration-info="approval_status == 'pending'" decoration-success="approval_status == 'approved'"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_approval_tree" model="ir.ui.view">
        <field name="name">project.project.approval.tree</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="approval_status" widget="badge" decoration-info="approval_status == 'pending'" decoration-success="approval_status == 'approved'"/>
            </xpath>
        </field>
    </record>

    <record id="view_blog_post_approval_list" model="ir.ui.view">
        <field name="name">blog.post.approval.list</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_published']" position="after">
                 <field name="approval_status" widget="badge" decoration-info="approval_status == 'pending'" decoration-success="approval_status == 'approved'" decoration-danger="approval_status == 'rejected'"/>
            </xpath>
        </field>
    </record>

</odoo>