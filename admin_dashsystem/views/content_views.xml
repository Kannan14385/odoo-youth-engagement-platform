<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_social_content" model="ir.actions.act_window">
        <field name="name">Content &amp; Blogs</field>
        <field name="res_model">social.content</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first article!</p>
        </field>
    </record>

    <record id="view_social_content_kanban" model="ir.ui.view">
        <field name="name">social.content.kanban</field>
        <field name="model">social.content</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="title"/>
                <field name="status"/>
                <field name="type"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="title"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <span class="badge text-bg-primary"><field name="type"/></span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_right">
                                    <field name="status" widget="label_selection" options="{'classes': {'draft': 'default', 'published': 'success', 'rejected': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_social_content_list" model="ir.ui.view">
        <field name="name">social.content.list</field>
        <field name="model">social.content</field>
        <field name="arch" type="xml">
            <list decoration-info="status == 'pending'" decoration-success="status == 'published'" decoration-danger="status == 'rejected'">
                <field name="title"/>
                <field name="author_id"/>
                <field name="type"/>
                <field name="publish_date"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_social_content_form" model="ir.ui.view">
        <field name="name">social.content.form</field>
        <field name="model">social.content</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit for Approval" type="object" class="oe_highlight"
                            invisible="status != 'draft'"/>

                    <button name="action_approve" string="Approve &amp; Publish" type="object" class="btn-success"
                            invisible="status != 'pending'"/>

                    <button name="action_reject" string="Reject" type="object" class="btn-danger"
                            invisible="status != 'pending'"/>

                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="status not in ('rejected', 'pending')"/>

                    <field name="status" widget="statusbar" statusbar_visible="draft,pending,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="title" placeholder="Article Title..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="author_id"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="publish_date"/>
                            <field name="sdg_tags"/>
                            </group>
                    </group>

                    <div class="alert alert-danger" role="alert" invisible="status != 'rejected'">
                        <strong>Rejection Reason:</strong> <field name="rejection_reason" readonly="1"/>
                    </div>

                    <notebook>
                        <page string="Content Body">
                            <field name="content" widget="html" options="{'collaborative': true}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>