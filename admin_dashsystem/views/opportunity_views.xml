<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_social_opportunity" model="ir.actions.act_window">
        <field name="name">Opportunities</field>
        <field name="res_model">social.opportunity</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Post a new Job, Internship, or Volunteering Opportunity!
            </p>
        </field>
    </record>

    <record id="view_social_opportunity_list" model="ir.ui.view">
        <field name="name">social.opportunity.list</field>
        <field name="model">social.opportunity</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'published'">
                <field name="name"/>
                <field name="org_id"/>
                <field name="type" widget="badge" decoration-warning="type == 'internship'" decoration-success="type == 'volunteer'"/>
                <field name="mode"/>
                <field name="date_deadline"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_social_opportunity_form" model="ir.ui.view">
        <field name="name">social.opportunity.form</field>
        <field name="model">social.opportunity</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" string="Publish Now" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close Opportunity" type="object" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,closed"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Opportunity Title"/>
                        <h1>
                            <field name="name" placeholder="e.g. Summer Social Media Intern"/>
                        </h1>
                        <label for="type" class="oe_edit_only"/>
                        <field name="type" widget="radio" options="{'horizontal': true}"/>
                    </div>

                    <group>
                        <group string="Key Details">
                            <field name="org_id"/>
                            <field name="date_posted"/>
                            <field name="date_deadline"/>
                        </group>
                        <group string="Logistics">
                            <field name="mode" widget="radio" options="{'horizontal': true}"/>
                            <field name="location" invisible="mode == 'remote'"/>
                            <field name="duration"/>
                            <field name="salary_stipend"/>
                            <field name="max_students"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Requirements &amp; Impact">
                            <group>
                                <group string="Candidate Requirements">
                                    <field name="qualification"/>
                                    <field name="subject_ids"/>
                                    <field name="skill_ids" widget="many2many_tags"/>
                                </group>
                                <group string="Social Impact">
                                    <field name="thematic_area_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Contact Information">
                            <group>
                                <group>
                                    <field name="contact_name"/>
                                    <field name="contact_email" widget="email"/>
                                    <field name="contact_phone" widget="phone"/>
                                </group>
                                <group>
                                    <div class="text-muted">
                                        These details will be visible to applicants.
                                    </div>
                                </group>
                            </group>
                        </page>

                        <page string="Full Description">
                            <field name="description" placeholder="Describe the role, responsibilities, and benefits in detail..."/>
                        </page>
                    </notebook>

                </sheet>

                </form>
        </field>
    </record>
</odoo>