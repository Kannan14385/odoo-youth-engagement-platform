<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="admin_system.SocialDashboard" owl="1">
        <div class="o_social_dashboard" style="height: 100%; overflow-y: auto; background-color: #f0f2f5; padding: 25px;">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">System Overview</h2>
                    <p class="text-dark opacity-75 mb-0" style="font-weight: 500;">Youth Engagement Platform Analytics</p>
                </div>
                <button class="btn btn-dark shadow-sm" t-on-click="() => this.fetchDashboardData()">
                    <i class="fa fa-refresh me-1"></i> Refresh Data
                </button>
            </div>

            <h5 class="text-uppercase text-dark fw-bold mb-3 small">Account Approvals &amp; Users</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm p-3 bg-white"
                         style="border-left: 5px solid #dc3545 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingUsers()">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-dark text-uppercase small fw-bold mb-1">User Requests</h6>
                                <h2 class="fw-bold text-danger mb-0"><t t-esc="state.pendingCount"/></h2>
                            </div>
                            <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                                <i class="fa fa-user-plus fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm p-3 bg-white" style="border-left: 5px solid #0d6efd !important;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-dark text-uppercase small fw-bold mb-1">Active Students</h6>
                                <h2 class="fw-bold text-dark mb-0"><t t-esc="state.studentCount"/></h2>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary"><i class="fa fa-graduation-cap fa-2x"></i></div>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="text-uppercase text-danger fw-bold mb-3 small">Content Awaiting Approval</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #dc3545 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.project', 'submitted', 'Pending Projects')">
                        <h4 class="fw-bold text-danger mb-1"><t t-esc="state.pendingProjects"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Projects</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #fd7e14 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.event', 'submitted', 'Pending Events')">
                        <h4 class="fw-bold text-warning mb-1"><t t-esc="state.pendingEvents"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Events</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #0dcaf0 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.blog', 'submitted', 'Pending Blogs')">
                        <h4 class="fw-bold text-info mb-1"><t t-esc="state.pendingBlogs"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Blogs</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #20c997 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.article', 'under_review', 'Pending Articles')">
                        <h4 class="fw-bold text-success mb-1"><t t-esc="state.pendingArticles"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Articles</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #6f42c1 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.opportunity', 'draft', 'Pending Opportunities')">
                        <h4 class="fw-bold text-primary mb-1"><t t-esc="state.pendingOpps"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Opps / Jobs</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #198754 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.grant', 'submitted', 'Pending Grants')">
                        <h4 class="fw-bold text-success mb-1"><t t-esc="state.pendingGrants"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Grants</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #ffc107 !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.skill.dev', 'draft', 'Pending Trainings')">
                        <h4 class="fw-bold text-warning mb-1"><t t-esc="state.pendingTrainings"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Trainings</h6>
                    </div>
                </div>
                <div class="col-md-2 col-sm-4">
                    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #6c757d !important; cursor: pointer;"
                         t-on-click="() => this.openPendingContent('youth.testimonial', 'draft', 'Pending Testimonials')">
                        <h4 class="fw-bold text-secondary mb-1"><t t-esc="state.pendingTestimonials"/></h4>
                        <h6 class="text-dark mb-0 small text-uppercase">Testimonies</h6>
                    </div>
                </div>
            </div>

            <h5 class="text-uppercase text-dark fw-bold mb-3 small">User Roles</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #0d6efd !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_student')"><div class="text-primary mb-2"><i class="fa fa-graduation-cap fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Students</h6></div></div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #0dcaf0 !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_professional')"><div class="text-info mb-2"><i class="fa fa-briefcase fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Professionals</h6></div></div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #ffc107 !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_ngo')"><div class="text-warning mb-2"><i class="fa fa-hand-holding-heart fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">NGOs</h6></div></div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #198754 !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_donor')"><div class="text-success mb-2"><i class="fa fa-money fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Donors</h6></div></div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #6f42c1 !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_csr')"><div class="text-white bg-white mb-2" style="color: #6f42c1 !important;"><i class="fa fa-building fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">CSR</h6></div></div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="border-top: 3px solid #212529 !important; cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_users_admin')"><div class="text-dark mb-2"><i class="fa fa-gavel fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Admins</h6></div></div>
            </div>

            <h5 class="text-uppercase text-dark fw-bold mb-3 small">Quick Access Menu</h5>
            <div class="row g-3 mb-4">

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('base.action_res_users')"><div class="text-secondary mb-2"><i class="fa fa-users fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">All Users</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('project.open_view_project_all')"><div class="text-info mb-2"><i class="fa fa-tasks fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Projects</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('event.action_event_view')"><div class="text-warning mb-2"><i class="fa fa-calendar fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Events</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('website_blog.action_blog_post')"><div class="text-danger mb-2"><i class="fa fa-rss fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Blogs</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_youth_article')"><div class="text-dark mb-2"><i class="fa fa-newspaper-o fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Articles</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_social_opportunity')"><div class="text-primary mb-2"><i class="fa fa-lightbulb-o fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Opportunities</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_social_grant')"><div class="text-success mb-2"><i class="fa fa-handshake-o fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Grants</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_social_skill_training')"><div class="text-info mb-2"><i class="fa fa-wrench fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Skill Dev</h6></div></div>

                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_social_award')"><div class="text-warning mb-2"><i class="fa fa-trophy fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Awards</h6></div></div>

                <div class="col-md-2 col-sm-4">
    <div class="card border-0 shadow-sm text-center p-3 btn-hover-effect position-relative" style="cursor: pointer;" t-on-click="() => this.openAction('admin_dashsystem.action_youth_testimonial')">

        <t t-if="state.pendingTestimonials > 0">
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" style="font-size: 0.85rem; z-index: 10;">
                <t t-esc="state.pendingTestimonials"/>
            </span>
        </t>
        <div class="text-success mb-2">
            <i class="fa fa-quote-left fa-2x"></i>
        </div>
        <h6 class="fw-bold text-dark mb-0">Testimonies</h6>
    </div>
</div>
                <div class="col-md-2 col-sm-4"><div class="card border-0 shadow-sm text-center p-3 btn-hover-effect" style="cursor: pointer;" t-on-click="() => this.openAction('website.action_website_menu')"><div class="text-primary mb-2"><i class="fa fa-globe fa-2x"></i></div><h6 class="fw-bold text-dark mb-0">Website</h6></div></div>

            </div>

        </div>
    </t>
</templates>