<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_social_system" model="ir.module.category">
            <field name="name">Social Admin System</field>
            <field name="description">Manage access levels for the Social Platform</field>
            <field name="sequence">10</field>
            <field name="visible" eval="True"/>
        </record>

        <record id="group_social_student" model="res.groups">
            <field name="name">Student / Youth</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Access for students to view their profile and apply for internships.</field>
        </record>

        <record id="group_social_professional" model="res.groups">
            <field name="name">Professional / Mentor</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_social_ngo" model="res.groups">
            <field name="name">NGO / Organization</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_social_donor" model="res.groups">
            <field name="name">Donor / CSR</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_social_csr" model="res.groups">
            <field name="name">CSR Company</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('group_social_donor'))]"/>
        </record>

        <record id="group_social_admin" model="res.groups">
            <field name="name">Social Administrator</field>
            <field name="category_id" ref="module_category_social_system"/>
            <field name="implied_ids" eval="[(4, ref('group_social_ngo')), (4, ref('group_social_csr')), (4, ref('base.group_system'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>