<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="rule_project_approval_visibility" model="ir.rule">
            <field name="name">Project: Own or Approved</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', '|', ('user_id', '=', user.id), ('create_uid', '=', user.id), ('approval_status', '=', 'approved')]</field>
        </record>

        <record id="rule_project_approval_admin" model="ir.rule">
            <field name="name">Project: Admin See All</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('admin_dashsystem.group_social_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_blog_approval_visibility" model="ir.rule">
            <field name="name">Blog: Own or Approved</field>
            <field name="model_id" ref="website_blog.model_blog_post"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|', ('author_id', '=', user.id), ('approval_status', '=', 'approved')]</field>
        </record>

    </data>
</odoo>