<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="rule_blog_post_admin_all" model="ir.rule">
            <field name="name">Blog: Admin Full Access</field>
            <field name="model_id" ref="website_blog.model_blog_post"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('admin_dashsystem.group_social_admin'))]"/>
        </record>

        <record id="rule_content_admin_all" model="ir.rule">
            <field name="name">Content: Admin Full Access</field>
            <field name="model_id" ref="model_social_content"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('admin_dashsystem.group_social_admin'))]"/>
        </record>

        <record id="rule_blog_post_own_or_approved" model="ir.rule">
            <field name="name">Blog: Own or Approved</field>
            <field name="model_id" ref="website_blog.model_blog_post"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('approval_status', '=', 'approved')]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_content_own_or_approved" model="ir.rule">
            <field name="name">Content: Own or Approved</field>
            <field name="model_id" ref="model_social_content"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('status', '=', 'published')]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>